class MyCalculator implements AdvancedArithmetic {
    /**
     * Finds and sums all divisors of n.
     * A divisor is any integer i where n % i == 0.
     */
    @Override
    public int divisor_sum(int n) {
        int sum = 0;
        // Iterate from 1 up to n to check for divisors
        for (int i = 1; i <= n; i++) {
            if (n % i == 0) {
                sum += i;
            }
        }
        return sum;
    }
}
