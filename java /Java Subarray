import java.util.Scanner;

public class Solution {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int[] a = new int[n];
        
        for (int i = 0; i < n; i++) {
            a[i] = sc.nextInt();
        }
        sc.close();

        int negativeSubarraysCount = 0;

        // Outer loop sets the starting point of the subarray
        for (int i = 0; i < n; i++) {
            int currentSum = 0;
            
            // Inner loop extends the subarray from the starting point to the end
            for (int j = i; j < n; j++) {
                currentSum += a[j];
                
                // If the sum of the current contiguous block is negative, count it
                if (currentSum < 0) {
                    negativeSubarraysCount++;
                }
            }
        }

        System.out.println(negativeSubarraysCount);
    }
}
