import java.util.*;

class Solution {
    public static void main(String[] argh) {
        Scanner in = new Scanner(System.in);
        
        // n: number of entries in the phone book
        int n = in.nextInt();
        in.nextLine(); // Consume the leftover newline
        
        // Initialize the HashMap (Key: Name, Value: Phone Number)
        HashMap<String, Integer> phoneBook = new HashMap<>();

        for (int i = 0; i < n; i++) {
            String name = in.nextLine();
            int phone = in.nextInt();
            in.nextLine(); // Consume the newline after the phone number
            
            // Store the entry in the map
            phoneBook.put(name, phone);
        }

        // Read queries until EOF (End-of-File)
        while (in.hasNext()) {
            String s = in.nextLine();
            
            // Check if the key exists in our map
            if (phoneBook.containsKey(s)) {
                System.out.println(s + "=" + phoneBook.get(s));
            } else {
                System.out.println("Not found");
            }
        }
        in.close();
    }
}

